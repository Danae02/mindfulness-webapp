APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Amsterdam
APP_URL=http://localhost

APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# Database
# ============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iedereen_mindful
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# Session & Cache
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
FILESYSTEM_DRIVER=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# ============================================
# Redis & Memcached
# ============================================
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# Mail
# ============================================
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# AWS (optioneel)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# Frontend & Encryption
# ============================================
VITE_APP_NAME="${APP_NAME}"

SODIUM_ENCRYPTION_KEY=
EMAIL_PEPPER=

# ============================================
# ADMIN ACCOUNTS
# ============================================

# Hannelies Hokke (Bartiméus supervisor)
ADMIN_HANNELIES_EMAIL=
ADMIN_HANNELIES_PASSWORD=

# Jessica Braakman (Bartiméus supervisor)
ADMIN_JESSICA_EMAIL=
ADMIN_JESSICA_PASSWORD=

# Affect-us algemeen email
ADMIN_AFFECTUS_EMAIL=
ADMIN_AFFECTUS_PASSWORD=
